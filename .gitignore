# Keep the repo focused on source files, docs, and curated examples.
*

!/.gitignore
!/.github/
!/.github/workflows/
!/.github/workflows/deploy-pages.yml
!/DEPLOY_GITHUB_PAGES.md
!/README.md
!/CODEX_CONTEXT.md
!/HANDOFF.md
!/SECURITY.md
!/landing-page/
!/landing-page/**
!/scripts/
!/scripts/**
!/templates/
!/templates/**
!/checklists/
!/checklists/**
!/offer/
!/offer/**
!/proof/
!/proof/**
!/operations/
!/operations/**
!/handoff/
!/handoff/**
!/improvement-plan/
!/improvement-plan/**

# Ignore generated or temporary artifacts even inside allowed folders.
*.bak
*.pyc
**/__pycache__/
**/.DS_Store

# Keep operational runtime data (and anything with real client PII) out of git by default.
/operations/logs/
/operations/outbox/
/operations/prospects/
/operations/plans/
/operations/delivery-log.csv
/clients/
/output/
/tmp/
